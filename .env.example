# Admin auth
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-super-secret

# Cloudflare Pages (D1 binding name)
# In Cloudflare Pages -> Settings -> Functions -> D1 databases -> Bind DB as "DB"

# Optional for drizzle-kit (local sqlite) generation only
DRIZZLE_DB_URL=file:./.wrangler/state/v3/d1/miniflare-D1DatabaseObject/db.sqlite
