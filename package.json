{
  "name": "auto_market",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:cf": "npx @cloudflare/next-on-pages@1 && npx wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.mjs",
    "pages:preview": "npx @cloudflare/next-on-pages@1"
  },
  "dependencies": {
    "drizzle-orm": "0.33.0",
    "next": "^14.2.25",
    "next-intl": "^3.25.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "styled-components": "6.1.13",
    "swiper": "^12.1.0",
    "yet-another-react-lightbox": "^3.29.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "1.13.7",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/styled-components": "5.1.34",
    "drizzle-kit": "0.24.2",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.25",
    "typescript": "5.5.4",
    "wrangler": "3.90.0"
  }
}
